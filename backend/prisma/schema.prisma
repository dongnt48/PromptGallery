generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            BigInt         @id @default(autoincrement())
  username      String         @unique @db.VarChar(50)
  email         String         @unique @db.VarChar(255)
  name          String?        @db.VarChar(100)
  passwordHash  String?        @map("password_hash") @db.VarChar(255)
  googleId      String?        @unique @map("google_id") @db.VarChar(255)
  avatarUrl     String?        @map("avatar_url") @db.VarChar(255)
  role          String         @default("user") @db.VarChar(20)
  bio           String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  isDelete      Boolean        @default(false) @map("is_delete")
  bookmarks     Bookmark[]
  likes         Like[]
  notifications Notification[]
  prompts       Prompt[]

  @@map("users")
}

model Prompt {
  id             BigInt      @id @default(autoincrement())
  userId         BigInt      @map("user_id")
  content        String
  negativePrompt String?     @map("negative_prompt")
  aiModel        String?     @map("ai_model") @db.VarChar(50)
  isPublic       Boolean     @default(true) @map("is_public")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  isDelete       Boolean     @default(false) @map("is_delete")
  source         String?     @db.VarChar(255)
  type           String?     @db.VarChar(50)
  bookmarks      Bookmark[]
  images         Image[]
  likes          Like[]
  tags           PromptTag[]
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([aiModel])
  @@index([createdAt(sort: Desc)])
  @@map("prompts")
}

model Image {
  id           BigInt   @id @default(autoincrement())
  promptId     BigInt   @map("prompt_id")
  imageUrl     String   @map("image_url") @db.VarChar(255)
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(255)
  isCover      Boolean  @default(false) @map("is_cover")
  createdAt    DateTime @default(now()) @map("created_at")
  prompt       Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId, isCover])
  @@map("images")
}

model Tag {
  id      BigInt      @id @default(autoincrement())
  name    String      @unique @db.VarChar(50)
  slug    String      @unique @db.VarChar(50)
  prompts PromptTag[]

  @@map("tags")
}

model PromptTag {
  promptId BigInt @map("prompt_id")
  tagId    BigInt @map("tag_id")
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
  @@map("prompt_tags")
}

model Like {
  userId    BigInt   @map("user_id")
  promptId  BigInt   @map("prompt_id")
  createdAt DateTime @default(now()) @map("created_at")
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, promptId])
  @@map("likes")
}

model Bookmark {
  userId    BigInt   @map("user_id")
  promptId  BigInt   @map("prompt_id")
  createdAt DateTime @default(now()) @map("created_at")
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, promptId])
  @@map("bookmarks")
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  message   String
  type      String   @default("info") @db.VarChar(20)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model RateLimitLog {
  id        BigInt   @id @default(autoincrement())
  ip        String   @db.VarChar(50)
  userId    String?  @map("user_id") @db.VarChar(50)
  path      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ip, createdAt(sort: Desc)])
  @@map("rate_limit_logs")
}
