# ==========================================
# MODOHA Environment Configuration Example
# ==========================================
# Copy this file to .env and configure the variables for your production environment.

# --- Database Setup (Used by docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_database_password_here
POSTGRES_DB=prompt_gallery

# --- Backend Configuration ---
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Update this to your production domain (e.g., https://api.yourdomain.com/auth/google/callback or http://your-ip:3000/auth/google/callback)
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Auth Security
# Generate a strong random string for JWT secret
JWT_SECRET=super_secure_random_jwt_secret_here

# The URL where your frontend is hosted (for CORS configuration in the backend)
FRONTEND_URL=http://localhost

# --- Frontend Configuration (Build-time variables) ---
# The public URL to reach your backend API
VITE_API_BASE=http://localhost:3000
# Must match the ENCRYPTION_KEY used for any frontend encryption needs
VITE_ENCRYPTION_KEY=v9y/B?E(H+MbQeThWmZq4t7w!z%C*F-J
